[global_config]
  dbus = False
  suppress_multiple_term_dialog = True
[keybindings]
[profiles]
  [[default]]
    font = Monaco 11
    scrollback_infinite = True
    use_system_font = False
[layouts]
  [[default]]
    [[[window0]]]
      type = Window
      size = 800, 450
      parent = ""
    [[[child1]]]
      type = Terminal
      parent = window0
      profile = default
[plugins]
