theme = wombat_custom

# 关闭自带的标题栏
#gtk-titlebar = false

gtk-wide-tabs = false

font-family = monaco
font-size = 11

# 退出不提示
confirm-close-surface = false

keybind = ctrl+t=new_tab
keybind = ctrl+w=close_surface
keybind = alt+left=previous_tab
keybind = alt+right=next_tab
keybind = f11=toggle_fullscreen
