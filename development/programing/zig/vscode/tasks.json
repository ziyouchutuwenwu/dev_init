{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "debug",
      "type": "shell",
      "command": "zig build",
      "group": "build"
    },
    {
      "label": "release",
      "type": "shell",
      "command": "zig build --release=safe",
      "group": "build"
    },
    {
      "label": "run",
      "type": "shell",
      "command": "zig build run"
    },
    {
      "label": "clean",
      "type": "shell",
      "command": "rm -rf zig-cache zig-out"
    },
    {
      "label": "test",
      "type": "shell",
      "command": "zig build test",
      "group": "test"
    }
  ]
}
