{
	// See https://go.microsoft.com/fwlink/?LinkId=733558
	// for the documentation about the tasks.json format
	"version": "2.0.0",
	"tasks": [
		{
			"label": "make",
			"type": "shell",
			"command": "make -j4"
		},
		{
			"label": "serial",
			"type": "shell",
			"command": "picocom -b 115200 -s 'sb -vv' -v 'rb -vv' /dev/ttyUSB0"
		},
		{
			"label": "burn",
			"type": "shell",
			//  请注意修改这里具体的板子配置文件
			"command": "openocd -f /home/mmc/dev/embedded/stm32/openocd/stm32f1x/jlink_board.cfg -c init -c 'reset halt' -c 'flash write_image erase xxx.bin 0x08000000' -c 'verify_image xxx.bin 0x08000000' -c 'reset run' -c shutdown"
		},
		{
			"label": "erase",
			"type": "shell",
			//  请注意修改这里具体的板子配置文件
			//  如果无法erase，请按住板子的reset键，再erase
			"command": "openocd -f /home/mmc/dev/embedded/stm32/openocd/stm32f1x/jlink_board.cfg -c init -c 'reset halt' -c 'flash info 0' -c 'flash erase_sector 0 0 last' -c 'flash erase_check 0' -c shutdown"
		}
	]
}