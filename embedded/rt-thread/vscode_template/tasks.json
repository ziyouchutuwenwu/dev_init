{
	// See https://go.microsoft.com/fwlink/?LinkId=733558
	// for the documentation about the tasks.json format
	"version": "2.0.0",
	"tasks": [
		{
			"label": "build",
			"type": "shell",
			"command": "scons -c; scons"
		},
		{
			"label": "serial",
			"type": "shell",
			"command": "picocom -b 115200 -s 'sb -vv' -v 'rb -vv' /dev/ttyUSB0"
		},
		{
			"label": "burn",
			"type": "shell",
			//  请注意修改这里具体的板子配置文件
			"command": "openocd -f /home/mmc/dev/embedded/stm32/openocd/stm32f1x/jlink_board.cfg -c init -c \"reset halt\" -c \"flash write_image erase rtthread.bin 0x08000000\" -c \"verify_image rtthread.bin 0x08000000\" -c \"reset run\" -c shutdown"
		},
		{
			"label": "JFlashLiteExe",
			"type": "shell",
			"command": "~/dev/embedded/stm32/JLink/JFlashLiteExe"
		},
	]
}